<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_TOP_VIEWS</name>
    <author>Custom Dev</author>
    <creationDate>2026-07</creationDate>
    <copyright>Copyright (C) 2026</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>1.0.0</version>
    <description>MOD_TOP_VIEWS_XML_DESCRIPTION</description>

    <files>
        <filename module="mod_top_views">mod_top_views.php</filename>
        <filename>helper.php</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>

    <languages>
        <language tag="en-GB">language/en-GB/en-GB.mod_top_views.ini</language>
        <language tag="en-GB">language/en-GB/en-GB.mod_top_views.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic">

                <field
                    name="catid"
                    type="sql"
                    label="MOD_TOP_VIEWS_FIELD_CATEGORY_LABEL"
                    description="MOD_TOP_VIEWS_FIELD_CATEGORY_DESC"
                    query="SELECT id AS value, title AS text FROM #__docshop_categories WHERE published = 1 ORDER BY title ASC"
                    key_field="value"
                    value_field="text"
                    multiple="true"
                    header="- Select Category -"
                />

                <field
                    name="count"
                    type="number"
                    default="5"
                    label="MOD_TOP_VIEWS_FIELD_COUNT_LABEL"
                    description="MOD_TOP_VIEWS_FIELD_COUNT_DESC"
                />

                <field
                    name="views_suffix"
                    type="text"
                    default="views"
                    label="MOD_TOP_VIEWS_FIELD_SUFFIX_LABEL"
                    description="MOD_TOP_VIEWS_FIELD_SUFFIX_DESC"
                />

                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_LAYOUT_DESC"
                />

                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    rows="3"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                />

                <field
                    name="cache"
                    type="list"
                    default="0"
                    label="COM_MODULES_FIELD_CACHING_LABEL"
                    description="COM_MODULES_FIELD_CACHING_DESC"
                    filter="integer"
                >
                    <option value="1">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
                </field>

                <field
                    name="cache_time"
                    type="text"
                    default="900"
                    label="COM_MODULES_FIELD_CACHE_TIME_LABEL"
                    description="COM_MODULES_FIELD_CACHE_TIME_DESC"
                />

            </fieldset>
        </fields>
    </config>
</extension>
