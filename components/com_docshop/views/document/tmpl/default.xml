<?xml version="1.0" encoding="utf-8"?>
<metadata>
    <layout title="COM_DOCSHOP_DOCUMENT_VIEW_DEFAULT_TITLE" option="COM_DOCSHOP_DOCUMENT_VIEW_DEFAULT_OPTION">
        <help key="JHELP_MENUS_MENU_ITEM_DOCUMENT_DETAIL" />
        <message><![CDATA[COM_DOCSHOP_DOCUMENT_VIEW_DEFAULT_DESC]]></message>
    </layout>

    <fields name="request">
        <fieldset name="request">
            <field
                name="id"
                type="sql"
                default=""
                label="COM_DOCSHOP_DOCUMENT_FIELD_ID_LABEL"
                description="COM_DOCSHOP_DOCUMENT_FIELD_ID_DESC"
                query="SELECT id AS value, title AS text FROM #__docshop_documents WHERE published = 1 ORDER BY title ASC"
                key_field="value"
                value_field="text"
                required="true"
            />
        </fieldset>
    </fields>

    <fields name="params">
        <fieldset name="basic">
            <field
                name="show_title"
                type="radio"
                default="1"
                label="COM_DOCSHOP_DOCUMENTS_SHOW_TITLE_LABEL"
                description="COM_DOCSHOP_DOCUMENTS_SHOW_TITLE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
        </fieldset>
    </fields>
</metadata>
