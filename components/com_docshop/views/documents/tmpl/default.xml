<?xml version="1.0" encoding="utf-8"?>
<metadata>
    <layout title="COM_DOCSHOP_DOCUMENTS_VIEW_DEFAULT_TITLE" option="COM_DOCSHOP_DOCUMENTS_VIEW_DEFAULT_OPTION">
        <help key="JHELP_MENUS_MENU_ITEM_DOCUMENTS" />
        <message><![CDATA[COM_DOCSHOP_DOCUMENTS_VIEW_DEFAULT_DESC]]></message>
    </layout>

    <!-- Fields in "request" are appended to the URL when the menu item is used -->
    <fields name="request">
        <fieldset name="request">
            <field
                name="filter_platform_id"
                type="sql"
                default="0"
                label="COM_DOCSHOP_PLATFORMS_FIELD_PLATFORM_LABEL"
                description="COM_DOCSHOP_PLATFORMS_FIELD_PLATFORM_DESC"
                query="SELECT id AS value, title AS text FROM #__docshop_platforms WHERE published = 1 ORDER BY title ASC"
                key_field="value"
                value_field="text"
            >
                <option value="">COM_DOCSHOP_PLATFORMS_FIELD_PLATFORM_ALL</option>
            </field>

            <field
                name="filter_category_id"
                type="sql"
                default="0"
                label="COM_DOCSHOP_CATEGORIES_FIELD_CATEGORY_LABEL"
                description="COM_DOCSHOP_CATEGORIES_FIELD_CATEGORY_DESC"
                query="SELECT id AS value, title AS text FROM #__docshop_categories WHERE published = 1 ORDER BY title ASC"
                key_field="value"
                value_field="text"
            >
                <option value="">COM_DOCSHOP_CATEGORIES_FIELD_CATEGORY_ALL</option>
            </field>
        </fieldset>
    </fields>

    <fields name="params">
        <fieldset name="basic">
            <field
                name="show_title"
                type="radio"
                default="1"
                label="COM_DOCSHOP_DOCUMENTS_SHOW_TITLE_LABEL"
                description="COM_DOCSHOP_DOCUMENTS_SHOW_TITLE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
        </fieldset>
    </fields>
</metadata>
